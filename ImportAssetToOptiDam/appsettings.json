{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/import-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId" ]
  },

  "OptimizelyCmp": {
    "BaseUrl": "https://api.cmp.optimizely.com",
    "TokenUrl": "https://accounts.cmp.optimizely.com/o/oauth2/v1/token",
    "ApiVersion": "v3",
    "TokenRefreshSkewSeconds": 60,
    "FieldsPageSize": 100,
    "FoldersPageSize": 100,

    // WARNING — SECURITY NOTICE
    // These credentials are stored in plain text. Anyone with read access to this
    // file (source control, build artifacts, CI logs, deployed copies) can use
    // them to impersonate this integration. Before shipping, replace with a
    // secure source:
    //   - Environment variables: OptimizelyCmp__ClientId / OptimizelyCmp__ClientSecret
    //   - Azure Key Vault / AWS Secrets Manager / HashiCorp Vault
    //   - User Secrets for local dev: dotnet user-secrets set "OptimizelyCmp:ClientId" "..."
    // Any of these will override the values below.
    "ClientId": "REPLACE_WITH_CLIENT_ID",
    "ClientSecret": "REPLACE_WITH_CLIENT_SECRET"
  },

  "Import": {
    "ImportFileName": "ImportAssetToOptiDam.xlsx",
    "ImportFolder": "ExcelSheet",
    "ImagesFolder": "Images",
    "SheetIndex": 0,
    "DefaultFolderId": null,
    "MaxDegreeOfParallelism": 1,
    "OutputFolder": "Output",
    "OutputFileName": "UploadReport-{date:yyyyMMdd}.xlsx"
  }
}
